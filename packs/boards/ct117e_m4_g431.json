    "Official I2C reference: I2C_HAL/i2c_hal.c",
    "CT117E_M4_SCH.pdf: SN74HC573 LED latch section",
    "CT117E_M4_SCH.pdf: B1/B2/B3/B4 push-button section"
  ]
