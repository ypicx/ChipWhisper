  "capabilities": [
    {
      "key": "board_display",
      "display_name": "板载 LCD 并口显示",
      "summary": "复用 CT117E-M4 板载 240x320 LCD，适合菜单、状态页和参数显示。",
      "module_kind": "ct117e_lcd_parallel",
      "recommended_name": "board_lcd",
      "category": "display",
      "notes": [
        "占用 PC0-PC15、PB9、PB8、PB5、PA8。",
        "更适合做板上 UI、菜单和状态显示。"
      ]
    },
    {
      "key": "board_keys_4",
      "display_name": "板载四按键",
      "summary": "复用 CT117E-M4 板载 4 个独立按键，适合菜单导航、参数设置和模式切换。",
      "module_kind": "key_bank_4_gpio",
      "recommended_name": "board_keys",
      "category": "input",
      "notes": [
        "固定到 PB0、PB1、PB2、PB14。",
        "默认按低电平按下处理。"
      ]
    },
    {
      "key": "board_leds_8",
      "display_name": "板载 8 灯锁存器",
      "summary": "复用 CT117E-M4 板载 8 个 LED，可做状态显示、流水灯和调试输出。",
      "module_kind": "ct117e_led_latch",
      "recommended_name": "board_leds",
      "category": "indicator",
      "notes": [
        "锁存使能脚为 PD2。",
        "数据脚与 LCD 高 8 位共用 PC8-PC15。"
      ]
    },
    {
      "key": "board_i2c_bus",
      "display_name": "板载 I2C 总线",
      "summary": "板级默认 I2C 走 PB6/PB7，可优先挂 EEPROM、数字电位器和常见 I2C 传感器。",
      "module_kind": "",
      "recommended_name": "",
      "category": "bus",
      "notes": [
        "SCL = PB6",
        "SDA = PB7"
      ]
    },
    {
      "key": "board_eeprom",
      "display_name": "板载 AT24C02",
      "summary": "可直接用于参数保存、配置记忆和简单掉电存储。",
      "module_kind": "at24c02_i2c",
      "recommended_name": "board_eeprom",
      "category": "storage",
      "notes": [
        "挂在板载 I2C 总线上。"
      ]
    },
    {
      "key": "board_digipot",
      "display_name": "板载 MCP4017",
      "summary": "可做数字电位器控制，适合演示可调阈值或信号调节。",
      "module_kind": "mcp4017_i2c",
      "recommended_name": "board_pot",
      "category": "control",
      "notes": [
        "挂在板载 I2C 总线上。"
      ]
    },
    {
      "key": "board_uart_debug",
      "display_name": "串口调试能力",
      "summary": "优先用 USART2 做日志输出，适合作为每个项目的默认调试链路。",
      "module_kind": "uart_debug",
      "recommended_name": "debug",
      "category": "debug",
      "notes": [
        "默认走 PA2/PA3。"
      ]
