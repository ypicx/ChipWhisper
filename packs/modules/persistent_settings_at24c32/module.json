{
  "schema_version": "1.0",
  "kind": "module",
  "key": "persistent_settings_at24c32",
  "display_name": "Persistent Settings AT24C32 Backend",
  "summary": "Example callback backend that stores one PersistentSettings instance inside an AT24C32 EEPROM with a 2-byte version header.",
  "hal_components": [],
  "template_files": [],
  "resource_requests": [],
  "depends_on": [
    "persistent_settings",
    "at24c32_i2c"
  ],
  "init_priority": 60,
  "loop_priority": 60,
  "c_callbacks_template": [
    "static HAL_StatusTypeDef PersistentSettingsAt24C32_ReadPayload(uint16_t memory_address, uint8_t *buffer, uint16_t length)",
    "{",
    "    if (length == 0U) {",
    "        return HAL_OK;",
    "    }",
    "    return AT24C32_ReadBuffer(&[[dep_at24c32_i2c_i2c_handle]], [[dep_at24c32_i2c_i2c_address_macro]], memory_address, buffer, length, [[option_timeout_ms|100]]);",
    "}",
    "",
    "static HAL_StatusTypeDef PersistentSettingsAt24C32_WritePayload(uint16_t memory_address, const uint8_t *buffer, uint16_t length)",
    "{",
    "    uint16_t offset = 0U;",
    "    while (offset < length) {",
    "        uint16_t chunk = (uint16_t)(length - offset);",
    "        HAL_StatusTypeDef status;",
    "        if (chunk > 32U) {",
    "            chunk = 32U;",
    "        }",
    "        status = AT24C32_WritePage(&[[dep_at24c32_i2c_i2c_handle]], [[dep_at24c32_i2c_i2c_address_macro]], (uint16_t)(memory_address + offset), &buffer[offset], chunk, [[option_timeout_ms|100]]);",
    "        if (status != HAL_OK) {",
    "            return status;",
    "        }",
    "        offset = (uint16_t)(offset + chunk);",
    "    }",
    "    return HAL_OK;",
    "}",
    "",
    "void PersistentSettings_OnDefaults(PersistentSettings *settings, uint8_t *data, uint16_t length)",
    "{",
    "    uint16_t index;",
    "    if (!PersistentSettings_Matches(settings, \"[[dep_persistent_settings_module_name]]\") || data == NULL) {",
    "        return;",
    "    }",
    "    for (index = 0U; index < length; ++index) {",
    "        data[index] = 0U;",
    "    }",
    "}",
    "",
    "HAL_StatusTypeDef PersistentSettings_OnLoad(PersistentSettings *settings, uint8_t *data, uint16_t length, uint16_t version)",
    "{",
    "    uint8_t header[2];",
    "    HAL_StatusTypeDef status;",
    "    uint16_t stored_version;",
    "    if (!PersistentSettings_Matches(settings, \"[[dep_persistent_settings_module_name]]\")) {",
    "        return HAL_ERROR;",
    "    }",
    "    status = PersistentSettingsAt24C32_ReadPayload((uint16_t)[[option_base_address|0]], header, 2U);",
    "    if (status != HAL_OK) {",
    "        return status;",
    "    }",
    "    stored_version = (uint16_t)((uint16_t)header[0] | ((uint16_t)header[1] << 8));",
    "    if (stored_version != version) {",
    "        return HAL_ERROR;",
    "    }",
    "    return PersistentSettingsAt24C32_ReadPayload((uint16_t)([[option_base_address|0]] + 2U), data, length);",
    "}",
    "",
    "HAL_StatusTypeDef PersistentSettings_OnSave(const PersistentSettings *settings, const uint8_t *data, uint16_t length, uint16_t version)",
    "{",
    "    uint8_t header[2];",
    "    HAL_StatusTypeDef status;",
    "    if (!PersistentSettings_Matches(settings, \"[[dep_persistent_settings_module_name]]\")) {",
    "        return HAL_ERROR;",
    "    }",
    "    header[0] = (uint8_t)(version & 0xFFU);",
    "    header[1] = (uint8_t)((version >> 8) & 0xFFU);",
    "    status = PersistentSettingsAt24C32_WritePayload((uint16_t)[[option_base_address|0]], header, 2U);",
    "    if (status != HAL_OK) {",
    "        return status;",
    "    }",
    "    return PersistentSettingsAt24C32_WritePayload((uint16_t)([[option_base_address|0]] + 2U), data, length);",
    "}",
    "",
    "void PersistentSettings_OnStatus(PersistentSettings *settings, HAL_StatusTypeDef status, uint8_t is_load)",
    "{",
    "    (void)settings;",
    "    (void)status;",
    "    (void)is_load;",
    "}"
  ],
  "notes": [
    "This example backend assumes exactly one PersistentSettings instance and one AT24C32 pack are present.",
    "The first two EEPROM bytes at base_address store the settings version in little-endian format."
  ],
  "sources": [
    "AT24C32 page-write pattern combined with a simple settings-version header."
  ]
}
